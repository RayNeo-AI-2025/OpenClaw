# ─────────────────────────────────────────────────────────────────────────────
#  local.properties.template — Compile-time configuration for OpenClaw
#
#  HOW TO USE（源码开发者）
#  ──────────
#  1. Copy this file and remove the ".template" suffix:
#       cp local.properties.template local.properties
#
#  2. Fill in your own keys below (remove the placeholder values).
#
#  3. Build normally — keys are injected into BuildConfig at compile time:
#       ./gradlew assembleDebug
#
#  SECURITY
#  ──────────
#  • This file contains secrets — never commit it to version control.
#    (.gitignore already excludes local.properties)
#  • Keys are baked into the APK at build time (BuildConfig).
#    If you later need to change keys WITHOUT rebuilding, use openclaw.conf
#    instead (see openclaw.conf.template).
#
#  PRIORITY（运行时覆盖 > 编译时注入）
#  ──────────
#  openclaw.conf (runtime, adb push) > local.properties (compile-time, baked in)
#  Any key present in openclaw.conf will override the value compiled in here.
#
# ─────────────────────────────────────────────────────────────────────────────

# Android SDK path (auto-generated by Android Studio — safe to leave as-is)
# sdk.dir=C\:\\Users\\YourName\\AppData\\Local\\Android\\Sdk

# ── Alibaba DashScope ASR ─────────────────────────────────────────────────────
# China users:         https://dashscope.console.aliyun.com/ → API-KEY 
# International users: https://bailian.console.alibabacloud.com/ → API-KEY
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WebSocket endpoint (international users MUST change this):
#   China (default):   wss://dashscope.aliyuncs.com/api-ws/v1/inference
#   International:     wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference
# Leave blank or omit to use the China endpoint (default).
# DASHSCOPE_WS_ENDPOINT=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference

# ASR model（海外用户须改为 fun-asr-realtime；paraformer-realtime-v2 仅限中国大陆）
# 留空则使用默认 paraformer-realtime-v2
# DASHSCOPE_ASR_MODEL=fun-asr-realtime

# ── OpenClaw Agent Gateway ────────────────────────────────────────────────────
# Base URL of your OpenClaw server (include port, no trailing slash)
OPENCLAW_BASE_URL=http://192.168.x.x:18789

# Gateway authentication token
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Agent ID to route requests to (default: main)
OPENCLAW_AGENT_ID=main
