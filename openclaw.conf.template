# ─────────────────────────────────────────────────────────────────────────────
#  openclaw.conf — Runtime configuration overlay for OpenClaw AR app
#
#  HOW TO USE
#  ──────────
#  1. Copy this file and remove the ".template" suffix:
#       cp openclaw.conf.template openclaw.conf
#
#  2. Fill in your own values below (uncomment lines and replace placeholders).
#
#  3. Push to the glasses once (no rebuild needed):
#       adb push openclaw.conf /sdcard/Android/data/com.openclaw.app/files/openclaw.conf
#
#  4. (Re-)launch the app — runtime values take effect immediately.
#
#  To update a value: edit this file → adb push again → relaunch.
#  To remove a key and fall back to the compiled-in BuildConfig value:
#    delete the line from the file → adb push again → relaunch.
#
#  SECURITY
#  ──────────
#  • This file contains secrets — never commit it to version control.
#    (.gitignore already excludes openclaw.conf)
#  • The file lives in the app's own external-files directory, so no
#    READ_EXTERNAL_STORAGE permission is required (Android 4.4+).
#  • Keys are logged to logcat at DEBUG level on startup; values are NOT.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Alibaba DashScope ASR ─────────────────────────────────────────────────────
# China users:         https://dashscope.console.aliyun.com/ → API-KEY 管理
# International users: https://bailian.console.alibabacloud.com/ → API-KEY 管理
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DashScope WebSocket endpoint ────────────────────────────────────────────
# International users MUST uncomment and use the international endpoint below.
# API keys from the China site and the international site are NOT interchangeable.
#   China (default):   wss://dashscope.aliyuncs.com/api-ws/v1/inference
#   International:     wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference
# DASHSCOPE_WS_ENDPOINT=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference

# ── ASR language ──────────────────────────────────────────────────────────────
# BCP-47 language code passed to DashScope as language_hints.
# Supported values (paraformer-realtime-v2):
#   zh  — 中文（默认）
#   en  — English
#   ja  — 日本語
#   ko  — 한국어
#   fr  — Français
#   de  — Deutsch
#   es  — Español
#   ru  — Русский
# Default: zh
# ASR_LANGUAGE=zh

# ── ASR listen mode ───────────────────────────────────────────────────────────
# Controls microphone behaviour after a complete utterance is recognised.
#
#   continuous  — keep recording until the user taps again.
#                 Best for back-and-forth conversation.  (default)
#
#   oneshot     — stop automatically after the first final transcript.
#                 The user must tap again for each new query.
#                 Best for precise single-query input.
#
# Default: continuous
# ASR_LISTEN_MODE=continuous

# ── Speech Engine Selection ───────────────────────────────────────────────────
# STT (speech-to-text) engine: "local" (sherpa-onnx on-device) or "dashscope"
# TTS (text-to-speech) engine: "local" (sherpa-onnx Piper on-device) or "none"
#
# To use local engines you must supply the sherpa-onnx AAR and model files
# (they are too large for git and must be downloaded separately):
#
#   1. Download the sherpa-onnx Android AAR and place it at:
#        app/libs/sherpa-onnx.aar
#      Pre-built AARs are available from:
#        https://github.com/k2-fsa/sherpa-onnx/releases
#
#   2. Download the streaming STT model and extract it into:
#        app/src/main/assets/sherpa-onnx-streaming-zipformer-en-20M-2023-02-17-mobile/
#      The model archive can be found at:
#        https://github.com/k2-fsa/sherpa-onnx/releases
#      Required files: encoder-epoch-99-avg-1.int8.onnx,
#                      decoder-epoch-99-avg-1.onnx,
#                      joiner-epoch-99-avg-1.int8.onnx,
#                      tokens.txt
#
#   3. Download the Piper VITS TTS model and extract it into:
#        app/src/main/assets/vits-piper-en_US-amy-low-int8/
#      Required files: en_US-amy-low.onnx, tokens.txt, espeak-ng-data/
#
#   4. Set STT_ENGINE=local and TTS_ENGINE=local below (or in openclaw.conf).
#
# To use DashScope cloud STT instead, set STT_ENGINE=dashscope and configure
# DASHSCOPE_API_KEY above. To disable TTS, set TTS_ENGINE=none.
#
# Default: local
STT_ENGINE=local

# Default: local
TTS_ENGINE=local

# ── OpenClaw Agent Gateway ────────────────────────────────────────────────────
# Base URL of your OpenClaw server (include port, no trailing slash)
OPENCLAW_BASE_URL=http://192.168.x.x:18789

# Gateway authentication token
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Agent ID to route requests to (default: main)
OPENCLAW_AGENT_ID=main
