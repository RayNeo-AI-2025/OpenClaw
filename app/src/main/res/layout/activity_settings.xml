<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020202">

    <!-- Title bar (text set dynamically in Kotlin) -->
    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:text="⚙  Settings"
        android:textColor="#00C896"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top divider -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#161614"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle" />

    <!-- ── Row 0: Listen Mode ─────────────────────────────────────── -->

    <LinearLayout
        android:id="@+id/rowListenMode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerTop">

        <TextView
            android:id="@+id/tvListenModeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Listen Mode"
            android:textColor="#484838"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvListenModeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continuous"
            android:textColor="#EEE8DC"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- ── Row 1: ASR Language ───────────────────────────────────── -->

    <LinearLayout
        android:id="@+id/rowLanguage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rowListenMode">

        <TextView
            android:id="@+id/tvLanguageLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ASR Language"
            android:textColor="#484838"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvLanguageValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chinese"
            android:textColor="#EEE8DC"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- ── Row 2: UI Language ────────────────────────────────────── -->

    <LinearLayout
        android:id="@+id/rowUiLanguage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rowLanguage">

        <TextView
            android:id="@+id/tvUiLanguageLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="UI Language"
            android:textColor="#484838"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvUiLanguageValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="English"
            android:textColor="#EEE8DC"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- ── Row 3: Reset Conversation (action, orange warning palette) ───── -->

    <LinearLayout
        android:id="@+id/rowReset"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rowUiLanguage">

        <TextView
            android:id="@+id/tvResetLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reset Chat"
            android:textColor="#4A3020"
            android:textSize="15sp" />

        <!-- No value TextView — this is a one-shot action, not a cycle -->

    </LinearLayout>

    <!-- Bottom hint bar (text set dynamically in Kotlin) -->
    <TextView
        android:id="@+id/tvSettingsHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="Swipe: Navigate  Tap: Change  2-tap: Save  3-tap: Cancel"
        android:textColor="#242420"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
